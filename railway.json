{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      "Dockerfile",
      "railway.json",
      "package.json",
      "package-lock.json",
      "apps/frontend/**",
      "apps/backend/**",
      "scripts/**"
    ]
  }
}
