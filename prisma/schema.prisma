generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./data.db"
}

/// Chamado sincronizado do GLPI (uma linha por `glpiTicketId`).
model Ticket {
  id                Int      @id @default(autoincrement())
  /// Identificador do chamado no GLPI.
  glpiTicketId      Int      @unique
  title             String?
  content           String?
  status            String?
  priority          String?
  dateCreation      String?
  dateModification  String?
  contractGroupId   Int?
  contractGroupName String?
  /** Nome de exibição do solicitante (melhor esforço a partir do JSON GLPI). */
  requesterName     String?
  /** E-mail do solicitante, se vier no payload da pesquisa GLPI. */
  requesterEmail    String?
  /** users_id do requerente no GLPI (útil para buscar User na API se faltar e-mail). */
  requesterUserId   Int?
  /** cliente | empresa | na | unknown — inferido pelo histórico GLPI (cache). */
  waitingParty      String?
  /// Payload bruto do GLPI (JSON) para campos não mapeados e enriquecimentos.
  rawJson           Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  attributes        TicketAttribute[]

  @@index([waitingParty])
  @@index([requesterEmail])
}

/// Atributo achatado do JSON do ticket (para pesquisas e filtros auxiliares).
model TicketAttribute {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  keyPath   String
  valueType String
  valueText String?
  valueJson String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([ticketId, keyPath])
  @@index([keyPath])
}

/// Chave-valor genérico (cursor de sync, escopo, totais, etc.).
model SyncState {
  key       String   @id
  value     String?
  updatedAt DateTime @updatedAt
}
