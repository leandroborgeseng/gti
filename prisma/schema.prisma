generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./data.db"
}

model Ticket {
  id                Int      @id @default(autoincrement())
  glpiTicketId      Int      @unique
  title             String?
  content           String?
  status            String?
  priority          String?
  dateCreation      String?
  dateModification  String?
  contractGroupId   Int?
  contractGroupName String?
  /** cliente | empresa | na | unknown — inferido pelo histórico GLPI (cache). */
  waitingParty      String?
  rawJson           Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  attributes        TicketAttribute[]

  @@index([waitingParty])
}

model TicketAttribute {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  keyPath   String
  valueType String
  valueText String?
  valueJson String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([ticketId, keyPath])
  @@index([keyPath])
}

model SyncState {
  key       String   @id
  value     String?
  updatedAt DateTime @updatedAt
}
