generator client {
  provider = "prisma-client-js"
  /// Relativo a este ficheiro (`apps/backend/prisma/`): raiz do monorepo → `node_modules/.prisma/client`.
  /// O `@prisma/client` hoisted na raiz (Docker / Railway) só funciona se o generate escrever aqui; caso contrário o Next falha em «Collecting page data».
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContractType {
  SOFTWARE
  DATACENTER
  INFRA
  SERVICO
}

enum LawType {
  LEI_8666
  LEI_14133
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum ContractFeatureStatus {
  NOT_STARTED
  IN_PROGRESS
  DELIVERED
  VALIDATED
}

/// Estado de entrega do item (funcionalidade) para acompanhamento da prestação do contrato.
enum ContractItemDeliveryStatus {
  NOT_DELIVERED
  PARTIALLY_DELIVERED
  DELIVERED
}

enum MeasurementStatus {
  OPEN
  UNDER_REVIEW
  APPROVED
  GLOSSED
}

enum MeasurementItemType {
  FEATURE
  SERVICE
}

enum GlosaType {
  ATRASO
  NAO_ENTREGA
  SLA
  QUALIDADE
}

enum GovernancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum GovernanceType {
  CORRETIVA
  EVOLUTIVA
}

enum TicketGovernanceStatus {
  OPEN
  ACKNOWLEDGED
  IN_PROGRESS
  SLA_VIOLATED
  EXTENDED_DEADLINE
  ESCALATED
  SENT_TO_CONTROLADORIA
}

enum TicketEventType {
  OPENED
  ACKNOWLEDGED
  SLA_VIOLATED
  MANAGER_NOTIFIED
  DEADLINE_EXTENDED
  ESCALATED
  SENT_TO_CONTROLADORIA
}

enum TicketWatcherRole {
  GESTOR
  CONTROLADORIA
  OBSERVADOR
}

enum GoalStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum GoalActionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum GoalLinkType {
  CONTRACT
  TICKET
}

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  passwordHash        String
  role                UserRole             @default(EDITOR)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Supplier {
  id        String     @id @default(uuid())
  name      String
  cnpj      String     @unique
  contracts Contract[]
}

model Fiscal {
  id                String     @id @default(uuid())
  name              String
  email             String     @unique
  phone             String
  contractsAsFiscal Contract[] @relation("ContractFiscal")
  contractsAsManager Contract[] @relation("ContractManager")
}

model Contract {
  id               String             @id @default(uuid())
  number           String             @unique
  name             String
  description      String?
  /// Órgão gestor no âmbito interno (ex.: secretaria responsável pelo contrato).
  managingUnit     String?
  companyName      String
  cnpj             String
  contractType     ContractType
  lawType          LawType
  startDate        DateTime
  endDate          DateTime
  totalValue       Decimal            @db.Decimal(18, 2)
  monthlyValue     Decimal            @db.Decimal(18, 2)
  /// Valor de implantação (único / projecto), separado da mensalidade.
  installationValue Decimal?          @db.Decimal(18, 2)
  /// Início do período em que predomina a cobrança/referência da implantação (data civil).
  implementationPeriodStart DateTime?
  /// Fim do período de implantação; após esta data considera-se a fase de mensalidade proporcional.
  implementationPeriodEnd   DateTime?
  status           ContractStatus
  slaTarget        Decimal?           @db.Decimal(5, 2)
  fiscalId         String
  managerId        String
  supplierId       String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?
  fiscal           Fiscal             @relation("ContractFiscal", fields: [fiscalId], references: [id])
  manager          Fiscal             @relation("ContractManager", fields: [managerId], references: [id])
  supplier         Supplier?          @relation(fields: [supplierId], references: [id])
  modules          ContractModule[]
  services         ContractService[]
  measurements     Measurement[]
  governanceTickets TicketGovernance[]
  amendments        ContractAmendment[]
  /** Grupos GLPI atribuídos aos chamados (alinhado a `Ticket.contractGroupId`) para métricas de SLA por contrato. */
  glpiGroups        ContractGlpiGroup[]
  /** Memória dos valores antes de alterações / renovações (consulta e comparação). */
  financialSnapshots ContractFinancialSnapshot[]

  @@index([status, endDate])
  @@index([deletedAt])
}

/// Registo pontual dos valores do contrato (ex.: antes de uma renovação), para comparar com os valores actuais.
model ContractFinancialSnapshot {
  id                String   @id @default(uuid())
  contractId        String
  recordedAt        DateTime @default(now())
  monthlyValue      Decimal  @db.Decimal(18, 2)
  totalValue        Decimal  @db.Decimal(18, 2)
  installationValue Decimal? @db.Decimal(18, 2)
  note              String?
  contract          Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, recordedAt])
}

/// Liga um contrato a um ou mais grupos de trabalho do GLPI (ID do grupo na instância sincronizada).
model ContractGlpiGroup {
  id            String   @id @default(uuid())
  contractId    String
  glpiGroupId   Int
  glpiGroupName String?
  createdAt     DateTime @default(now())
  contract      Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, glpiGroupId])
  @@index([glpiGroupId])
}

/// Registo de aditivo ou reajuste formal (valores e vigência); aplica alterações ao contrato na criação.
model ContractAmendment {
  id                   String   @id @default(uuid())
  contractId           String
  referenceCode        String?
  effectiveDate        DateTime
  description          String
  previousTotalValue   Decimal  @db.Decimal(18, 2)
  previousMonthlyValue Decimal  @db.Decimal(18, 2)
  previousEndDate      DateTime
  newTotalValue        Decimal  @db.Decimal(18, 2)
  newMonthlyValue      Decimal  @db.Decimal(18, 2)
  newEndDate           DateTime
  createdAt            DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Restrict)

  @@index([contractId, createdAt])
}

model ContractModule {
  id         String            @id @default(uuid())
  contractId String
  name       String
  weight     Decimal           @db.Decimal(8, 4)
  contract   Contract          @relation(fields: [contractId], references: [id], onDelete: Restrict)
  features   ContractFeature[]
}

model ContractFeature {
  id             String                     @id @default(uuid())
  moduleId       String
  name           String
  weight         Decimal                    @db.Decimal(8, 4)
  status         ContractFeatureStatus      @default(NOT_STARTED)
  deliveryStatus ContractItemDeliveryStatus @default(NOT_DELIVERED)
  module         ContractModule             @relation(fields: [moduleId], references: [id], onDelete: Restrict)
}

model ContractService {
  id         String   @id @default(uuid())
  contractId String
  name       String
  unit       String
  unitValue  Decimal  @db.Decimal(18, 4)
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Restrict)
}

model Measurement {
  id                 String             @id @default(uuid())
  contractId         String
  referenceMonth     Int
  referenceYear      Int
  status             MeasurementStatus  @default(OPEN)
  totalMeasuredValue Decimal            @default(0) @db.Decimal(18, 2)
  totalApprovedValue Decimal            @default(0) @db.Decimal(18, 2)
  totalGlosedValue   Decimal            @default(0) @db.Decimal(18, 2)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?
  contract           Contract           @relation(fields: [contractId], references: [id], onDelete: Restrict)
  items              MeasurementItem[]
  glosas             Glosa[]
  attachments        Attachment[]

  @@unique([contractId, referenceMonth, referenceYear])
}

model MeasurementItem {
  id              String              @id @default(uuid())
  measurementId   String
  type            MeasurementItemType
  referenceId     String
  quantity        Decimal             @db.Decimal(18, 4)
  calculatedValue Decimal             @db.Decimal(18, 2)
  measurement     Measurement         @relation(fields: [measurementId], references: [id], onDelete: Restrict)
}

model Glosa {
  id            String   @id @default(uuid())
  measurementId String
  type          GlosaType
  value         Decimal  @db.Decimal(18, 2)
  justification String
  createdBy     String
  createdAt     DateTime @default(now())
  measurement   Measurement @relation(fields: [measurementId], references: [id], onDelete: Restrict)
  attachments   Attachment[]
}

model AuditLog {
  id        String   @id @default(uuid())
  entity    String
  entityId  String
  action    String
  userId    String
  timestamp DateTime @default(now())
  oldData   Json?
  newData   Json?
}

model TicketGovernance {
  id                     String                 @id @default(uuid())
  ticketId               String
  contractId             String
  openedAt               DateTime
  acknowledgedAt         DateTime?
  priority               GovernancePriority?
  type                   GovernanceType?
  slaDeadline            DateTime?
  firstResponseAt        DateTime?
  resolvedAt             DateTime?
  status                 TicketGovernanceStatus @default(OPEN)
  managerNotified        Boolean                @default(false)
  controladoriaNotified  Boolean                @default(false)
  seiProcessNumber       String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  contract               Contract               @relation(fields: [contractId], references: [id], onDelete: Restrict)
  deadlineExtensions     TicketDeadlineExtension[]
  eventLogs              TicketEventLog[]
  watchers               TicketWatcher[]

  @@index([ticketId])
  @@index([status, slaDeadline])
}

model TicketDeadlineExtension {
  id                 String           @id @default(uuid())
  ticketGovernanceId String
  previousDeadline   DateTime
  newDeadline        DateTime
  justification      String
  createdBy          String
  createdAt          DateTime         @default(now())
  ticketGovernance   TicketGovernance @relation(fields: [ticketGovernanceId], references: [id], onDelete: Restrict)
}

model TicketEventLog {
  id                 String           @id @default(uuid())
  ticketGovernanceId String
  type               TicketEventType
  description        String
  createdAt          DateTime         @default(now())
  ticketGovernance   TicketGovernance @relation(fields: [ticketGovernanceId], references: [id], onDelete: Restrict)
}

model TicketWatcher {
  id                 String           @id @default(uuid())
  ticketGovernanceId String
  userId             String
  role               TicketWatcherRole
  ticketGovernance   TicketGovernance @relation(fields: [ticketGovernanceId], references: [id], onDelete: Restrict)

  @@unique([ticketGovernanceId, userId, role])
}

model Goal {
  id            String       @id @default(uuid())
  title         String
  description   String?
  year          Int
  status        GoalStatus   @default(PLANNED)
  priority      String
  responsibleId String
  createdAt     DateTime     @default(now())
  actions       GoalAction[]
  links         GoalLink[]

  @@index([year, status])
}

model GoalAction {
  id            String         @id @default(uuid())
  goalId         String
  title          String
  description    String?
  status         GoalActionStatus @default(NOT_STARTED)
  progress       Int            @default(0)
  dueDate        DateTime?
  responsibleId  String
  goal           Goal           @relation(fields: [goalId], references: [id], onDelete: Restrict)
}

model GoalLink {
  id          String      @id @default(uuid())
  goalId      String
  type        GoalLinkType
  referenceId String
  goal        Goal        @relation(fields: [goalId], references: [id], onDelete: Restrict)
}

model Attachment {
  id              String       @id @default(uuid())
  fileName        String
  mimeType        String
  filePath        String
  measurementId   String?
  glosaId         String?
  projectTaskId   String?
  createdAt       DateTime     @default(now())
  measurement     Measurement? @relation(fields: [measurementId], references: [id], onDelete: Restrict)
  glosa           Glosa?       @relation(fields: [glosaId], references: [id], onDelete: Restrict)
  projectTask     ProjectTask? @relation(fields: [projectTaskId], references: [id], onDelete: Cascade)

  @@index([projectTaskId])
}

// ---------------------------------------------------------------------------
// Projetos (importação Excel / Monday.com) — independente do Kanban GLPI
// ---------------------------------------------------------------------------

model Project {
  id              String         @id @default(uuid())
  name            String
  parentProjectId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  parentProject   Project?       @relation("ProjectHierarchy", fields: [parentProjectId], references: [id], onDelete: SetNull)
  subprojects     Project[]      @relation("ProjectHierarchy")
  groups          ProjectGroup[]
  tasks           ProjectTask[]

  @@index([parentProjectId])
}

model ProjectGroup {
  id        String        @id @default(uuid())
  projectId String
  name      String
  sortOrder Int           @default(0)
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     ProjectTask[]

  @@index([projectId, sortOrder])
}

model ProjectTask {
  id                  String    @id @default(uuid())
  projectId           String
  groupId             String
  parentTaskId        String?
  title               String
  status              String    @default("")
  assigneeExternal    String?
  dueDate             DateTime?
  description         String?   @db.Text
  effort              Decimal?  @db.Decimal(18, 4)
  internalResponsible String?
  sortOrder           Int       @default(0)
  project             Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  group               ProjectGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  parent              ProjectTask?  @relation("ProjectTaskHierarchy", fields: [parentTaskId], references: [id], onDelete: Cascade)
  children            ProjectTask[] @relation("ProjectTaskHierarchy")
  attachments         Attachment[]

  @@index([projectId, groupId])
  @@index([parentTaskId])
}

// ---------------------------------------------------------------------------
// Cache de sincronização GLPI (Kanban / worker) — mesmo PostgreSQL que o Nest
// ---------------------------------------------------------------------------

/// Chamado sincronizado do GLPI (uma linha por `glpiTicketId`).
model Ticket {
  id                 Int      @id @default(autoincrement())
  /// Identificador do chamado no GLPI.
  glpiTicketId       Int      @unique
  title              String?
  content            String?  @db.Text
  status             String?
  priority           String?
  dateCreation       String?
  dateModification   String?
  contractGroupId    Int?
  contractGroupName  String?
  requesterName      String?
  requesterEmail     String?
  requesterUserId    Int?
  /// Técnico / utilizador atribuído no GLPI (`users_id_tech` + nome na equipa quando existir).
  assignedUserId     Int?
  assignedUserName   String?
  /// cliente | empresa | na | unknown — inferido pelo histórico GLPI (cache).
  waitingParty       String?
  rawJson            Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  attributes         TicketAttribute[]

  @@index([waitingParty])
  @@index([requesterEmail])
  @@index([assignedUserId])
  @@index([status, dateCreation])
  @@index([dateModification])
}


/// Atributo achatado do JSON do ticket (pesquisas e filtros auxiliares).
model TicketAttribute {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  keyPath   String
  valueType String
  valueText String?  @db.Text
  valueJson String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([ticketId, keyPath])
  @@index([keyPath])
}

/// Chave-valor genérico (cursor de sync, escopo Kanban, etc.).
model SyncState {
  key       String   @id
  value     String?  @db.Text
  updatedAt DateTime @updatedAt
}
