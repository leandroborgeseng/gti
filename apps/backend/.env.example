DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gti_contratos?schema=public"
PORT=4000

# JWT (login API). Em produção defina JWT_SECRET forte e não use o valor por padrão do código.
# JWT_EXPIRES_IN=7d
# JWT_SECRET=

# Primeiro usuário (seed: `npx prisma db seed` a partir da raiz do monorepo).
# BOOTSTRAP_ADMIN_EMAIL=admin@local.dev
# BOOTSTRAP_ADMIN_PASSWORD=admin123

# Anexos (medições / glosas): pasta no disco e limite em MB. Opcional: UPLOAD_EXTRA_MIME=application/octet-stream,...
UPLOAD_ROOT=./uploads
UPLOAD_MAX_MB=10

# Migrações (inclui tabelas do cache GLPI: Ticket, TicketAttribute, SyncState):
#   npm run prisma:migrate   — desenvolvimento
#   npm run prisma:deploy    — CI / produção
