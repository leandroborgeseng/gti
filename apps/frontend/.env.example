# =============================================================================
# Frontend Next (apps/frontend) — copie para .env.local
# =============================================================================

# Mesmo PostgreSQL que `apps/backend` (Prisma). Obrigatório para o Kanban GLPI e APIs /api/*.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gti_contratos?schema=public"

# URL pública desta app (metadata, PWA, links absolutos). Em produção: https://seu-dominio
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Opcional: API Nest noutro host (contratos, medições, etc.). Se omitir, o browser usa o mesmo site (`/api/...`).
# NEXT_PUBLIC_BACKEND_URL=http://localhost:4000/api

# --- GLPI (Kanban e sincronização no mesmo processo Next) ---
# Alternativa na Railway (uma única variável): `GTI_ENV_JSON` = objeto JSON numa linha com as chaves
# GLPI_* e DATABASE_URL (a Railway pode expandir ${{Postgres.DATABASE_URL}} dentro do valor ao gravar).
# Não commite segredos no Git. Ficheiro local opcional: copie `config/glpi-env.local.json.example` para
# `config/glpi-env.local.json` (está no .gitignore).
#
# Copie também as variáveis do ficheiro `.env` na raiz do monorepo ou duplique aqui.
# O código carrega `../../.env`, `../../.env.local`, `.env` e `.env.local` (nesta ordem).
# GLPI_BASE_URL pode ser `https://host/api.php`, `https://host/apirest.php` ou só `https://host` (assume /api.php).
GLPI_BASE_URL=https://suporte.exemplo.gov.br/api.php
# Opcional: URL absoluta do token OAuth2 se não for `{GLPI_BASE_URL}/token`.
# GLPI_TOKEN_URL=
GLPI_DOC_URL=https://suporte.exemplo.gov.br/api.php/v2.2.0/doc.json
GLPI_TICKETS_PATH=/v2/Assistance/Ticket
GLPI_CLIENT_ID=
GLPI_CLIENT_SECRET=
GLPI_USERNAME=
GLPI_PASSWORD=
GLPI_OAUTH_SCOPE=api
GLPI_USER_AGENT=glpi-sync-mvp/1.0
CRON_EXPRESSION=*/5 * * * *
HTTP_TIMEOUT_MS=20000

# Desempenho da sync GLPI (opcional; há limites no código). Padrão: 300 tickets/página, 8 páginas em paralelo no GLPI, 12 upserts em paralelo na BD.
# GLPI_TICKETS_PAGE_SIZE=300
# GLPI_TICKETS_FETCH_CONCURRENCY=8
# GLPI_SYNC_PERSIST_CONCURRENCY=12

# Opcional: permite POST /api/glpi/sync com cabeçalho `x-gti-glpi-sync-secret` igual a este valor (forçar sync).
# GLPI_SYNC_TRIGGER_SECRET=

# Opcional: após quantos ms sem `lastFinishedAt` a BD é considerada órfã e normalizada antes da próxima sync (padrão 4 h).
# GLPI_SYNC_ORPHAN_MS=14400000
