# =============================================================================
# Frontend Next (apps/frontend) — copie para .env.local
# =============================================================================

# Mesmo PostgreSQL que `apps/backend` (Prisma). Obrigatório para o Kanban GLPI e APIs /api/*.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gti_contratos?schema=public"

# URL pública desta app (metadata, PWA, links absolutos). Em produção: https://seu-dominio
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# API Nest (contratos, medições, dashboard, etc.)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000/api

# --- GLPI (Kanban e sincronização no mesmo processo Next) ---
# Copie também as variáveis do ficheiro `.env` na raiz do monorepo ou duplique aqui.
# O código carrega `../../.env`, `../../.env.local`, `.env` e `.env.local` (nesta ordem).
# GLPI_BASE_URL pode ser `https://host/api.php`, `https://host/apirest.php` ou só `https://host` (assume /api.php).
GLPI_BASE_URL=https://suporte.exemplo.gov.br/api.php
# Opcional: URL absoluta do token OAuth2 se não for `{GLPI_BASE_URL}/token`.
# GLPI_TOKEN_URL=
GLPI_DOC_URL=https://suporte.exemplo.gov.br/api.php/v2.2.0/doc.json
GLPI_TICKETS_PATH=/v2/Assistance/Ticket
GLPI_CLIENT_ID=
GLPI_CLIENT_SECRET=
GLPI_USERNAME=
GLPI_PASSWORD=
GLPI_OAUTH_SCOPE=api
GLPI_USER_AGENT=glpi-sync-mvp/1.0
CRON_EXPRESSION=*/5 * * * *
HTTP_TIMEOUT_MS=20000
