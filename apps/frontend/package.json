    "jose": "^5.9.6",
    "next": "^14.2.7",
    "node-cron": "^3.0.3",
    "pino": "^9.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-quill": "^2.0.0",
    "recharts": "^2.13.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "browserslist": "^4.28.2",
    "caniuse-lite": "^1.0.30001788",
    "postcss": "^8.4.47",
    "prisma": "^6.6.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  }
