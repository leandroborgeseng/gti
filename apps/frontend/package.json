{
  "name": "gti-contratos-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "typecheck": "tsc --noEmit",
    "build": "prisma generate --schema ../backend/prisma/schema.prisma && GLPI_SKIP_BOOTSTRAP=1 next build",
    "start": "next start -p ${PORT:-3001}",
    "prisma:generate": "prisma generate --schema ../backend/prisma/schema.prisma"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "dotenv": "^16.4.5",
    "next": "^14.2.7",
    "node-cron": "^3.0.3",
    "pino": "^9.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prisma": "^6.6.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  }
}
