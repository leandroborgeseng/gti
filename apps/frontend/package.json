{
  "name": "gti-contratos-frontend",
  "version": "1.0.1",
  "private": true,
  "scripts": {
    "dev": "npx next dev -p 3001",
    "typecheck": "tsc --noEmit",
    "build": "prisma generate --schema ../backend/prisma/schema.prisma && GLPI_SKIP_BOOTSTRAP=1 npx next build",
    "start": "npx next start -H 0.0.0.0 -p ${PORT:-3000}",
    "prisma:generate": "prisma generate --schema ../backend/prisma/schema.prisma"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
