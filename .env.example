# =============================================================================
# GTI — exemplo de variáveis de ambiente (copie para .env e preencha)
# =============================================================================

# URL base da API GLPI (normalmente termina em /api.php)
GLPI_BASE_URL=https://suporte.exemplo.gov.br/api.php

# URL do documento OpenAPI do GLPI (doc.json), usado para descobrir o endpoint de tickets
GLPI_DOC_URL=https://suporte.exemplo.gov.br/api.php/v2.2.0/doc.json

# Caminho dos tickets na API v2 (ajuste se o seu GLPI usar outro caminho)
GLPI_TICKETS_PATH=/v2/Assistance/Ticket

# Credenciais OAuth da aplicação registada no GLPI
GLPI_CLIENT_ID=
GLPI_CLIENT_SECRET=

# Utilizador GLPI com permissão para ler/atualizar chamados via API
GLPI_USERNAME=
GLPI_PASSWORD=

# âmbito OAuth (em geral "api")
GLPI_OAUTH_SCOPE=api

# Identificação do cliente HTTP nas chamadas ao GLPI
GLPI_USER_AGENT=glpi-sync-mvp/1.0

# Expressão cron: frequência da sincronização incremental (padrão: a cada 5 minutos)
CRON_EXPRESSION=*/5 * * * *

# Tempo máximo de espera por pedido HTTP (milissegundos)
HTTP_TIMEOUT_MS=20000

# Porta do servidor HTTP local
# PORT=3000

# Nível de log do Pino (ex.: info, debug)
# LOG_LEVEL=info

# Opcional: mais tickets por pedido ao GLPI (50–500) e várias páginas em paralelo (1–12)
# GLPI_TICKETS_PAGE_SIZE=250
# GLPI_TICKETS_FETCH_CONCURRENCY=4
