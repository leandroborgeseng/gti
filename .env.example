GLPI_BASE_URL=https://suporte.franca.sp.gov.br/api.php
GLPI_DOC_URL=https://suporte.franca.sp.gov.br/api.php/v2.2.0/doc.json
GLPI_TICKETS_PATH=/v2/Assistance/Ticket
GLPI_CLIENT_ID=
GLPI_CLIENT_SECRET=
GLPI_USERNAME=
GLPI_PASSWORD=
GLPI_OAUTH_SCOPE=api
GLPI_USER_AGENT=glpi-sync-mvp/1.0
CRON_EXPRESSION=*/5 * * * *
HTTP_TIMEOUT_MS=20000
# Opcional: sincronizacao GLPI mais rapida (paginas maiores + varias paginas em paralelo)
# GLPI_TICKETS_PAGE_SIZE=250
# GLPI_TICKETS_FETCH_CONCURRENCY=4
