# =============================================================================
# Exemplo de variáveis de ambiente — Gestão de Operações de TI (copie para .env e preencha)
# =============================================================================

# Docker Compose: ficheiro `.env` na raiz (ver `docker-compose.yml`) com `DATABASE_URL` e `GLPI_*`.
# O Postgres **não** vai dentro da imagem — use um serviço gerido (Railway, etc.).

# PostgreSQL partilhado com `apps/backend` (Nest) e com o worker / Next (Prisma).
# O mesmo valor deve existir em `apps/backend/.env` e em `apps/frontend/.env.local`.
# Na Railway, use a variável gerada pelo plugin Postgres; em muitos casos acrescente `?sslmode=require`
# (ou `&sslmode=require` se já houver query string) para TLS.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gti_contratos?schema=public"

# JWT HS256 partilhado entre o login Next (`apps/frontend`) e a API Nest (`apps/backend`). Em produção use segredo forte.
# JWT_SECRET=
# JWT_EXPIRES_IN=7d

# Resend: envio de e-mails transacionais (boas-vindas, redefinição de senha e alertas futuros).
# Use uma chave gerada no painel do Resend e um remetente/domínio verificado.
# RESEND_API_KEY=
# RESEND_FROM="GTI <gti@bluebeaver.com.br>"

# Gestão contratual via Next (proxy): ver `apps/frontend/.env.example` — BACKEND_API_BASE_URL, NEXT_PUBLIC_BACKEND_URL.

# URL base da API GLPI (`.../api.php` ou `.../apirest.php`; pode ser só a origem `https://host`)
GLPI_BASE_URL=https://suporte.exemplo.gov.br/api.php
# Mesmo valor que GLPI_BASE_URL (exposto ao browser para HTML do Kanban; obrigatório em deploy Next).
NEXT_PUBLIC_GLPI_BASE_URL=https://suporte.exemplo.gov.br/api.php
# Opcional: token OAuth2 fora do padrão `{GLPI_BASE_URL}/token`
# GLPI_TOKEN_URL=

# URL do documento OpenAPI do GLPI (doc.json), usado para descobrir o endpoint de tickets
GLPI_DOC_URL=https://suporte.exemplo.gov.br/api.php/v2.2.0/doc.json

# Caminho dos tickets na API v2 (ajuste se o seu GLPI usar outro caminho)
GLPI_TICKETS_PATH=/v2/Assistance/Ticket

# Credenciais OAuth da aplicação registada no GLPI
GLPI_CLIENT_ID=
GLPI_CLIENT_SECRET=

# Utilizador GLPI com permissão para ler/atualizar chamados via API
GLPI_USERNAME=
GLPI_PASSWORD=

# âmbito OAuth (em geral "api")
GLPI_OAUTH_SCOPE=api

# Identificação do cliente HTTP nas chamadas ao GLPI
GLPI_USER_AGENT=glpi-sync-mvp/1.0

# Expressão cron: frequência da sincronização incremental (padrão: a cada 5 minutos)
CRON_EXPRESSION=*/5 * * * *

# Opcional: em réplicas Next sem worker dedicado, evite cron duplicado (valor "1" desliga o agendamento no processo).
# GLPI_CRON_DISABLED=1

# Tempo máximo de espera por pedido HTTP (milissegundos)
HTTP_TIMEOUT_MS=20000

# Porta do servidor HTTP local
# PORT=3000

# O Kanban e as APIs GLPI vivem na app Next (`apps/frontend`, rota /chamados).
# Defina as variáveis GLPI_* também em apps/frontend/.env.local em desenvolvimento.

# Nível de log do Pino: em produção use `info` ou `warn` (menos ruído).
# Detalhe por página GLPI e “sem grupo técnico” só aparecem com `debug`.
# LOG_LEVEL=info

# Opcional: mais tickets por pedido ao GLPI (50–500) e várias páginas em paralelo (1–12)
# GLPI_TICKETS_PAGE_SIZE=250
# GLPI_TICKETS_FETCH_CONCURRENCY=4
