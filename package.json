{
  "name": "glpi-sync-mvp",
  "version": "1.0.0",
  "description": "Sincronização de chamados GLPI para PostgreSQL (partilhado com o backend Nest), Kanban Next e worker Node (TypeScript + Prisma).",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "postinstall": "prisma generate --schema apps/backend/prisma/schema.prisma",
    "build": "cd apps/frontend && npm ci && npm run build",
    "start": "npm run prisma:deploy && cd apps/frontend && npm run start",
    "start:worker": "tsx src/index.ts",
    "dev": "tsx src/index.ts",
    "sync": "tsx src/index.ts",
    "smoke:regression": "tsx src/scripts/regression-smoke.ts",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate --schema apps/backend/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema apps/backend/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema apps/backend/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "axios": "^1.9.0",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3",
    "pino": "^9.3.2",
    "prisma": "^6.6.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.6.3"
  }
}
