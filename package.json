{
  "name": "glpi-sync-mvp",
  "version": "1.0.1",
  "description": "Kanban GLPI e gestão contratual em Next.js; worker de sync opcional (código em apps/frontend).",
  "private": true,
  "type": "commonjs",
  "prisma": {
    "seed": "cd apps/backend && npm run prisma:seed"
  },
  "scripts": {
    "postinstall": "prisma generate --schema apps/backend/prisma/schema.prisma",
    "build": "npm ci && cd apps/frontend && npm ci && npm run build",
    "start": "npm run prisma:deploy && cd apps/frontend && npm run start",
    "start:worker": "tsx apps/frontend/scripts/glpi-worker-cli.ts",
    "dev": "cd apps/frontend && npm run dev",
    "dev:worker": "tsx apps/frontend/scripts/glpi-worker-cli.ts",
    "sync": "tsx apps/frontend/scripts/glpi-worker-cli.ts",
    "smoke:regression": "tsx scripts/regression-smoke.ts",
    "typecheck": "npm run prisma:generate && (cd apps/frontend && npm run typecheck) && (cd apps/backend && npm run typecheck)",
    "prisma:generate": "prisma generate --schema apps/backend/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema apps/backend/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema apps/backend/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "prisma": "^6.6.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.6.3"
  }
}
